# Example GitHub Actions workflow for CI/CD
# Demonstrates seed-based reproducibility for property-based tests
#
# To use this file:
# 1. Rename to .github/workflows/test.yml
# 2. Commit and push to your repository
# 3. GitHub Actions will automatically run tests on push and pull requests

name: Test Suite

on:
  push:
    branches: [ main, develop ]
  pull_request:
    branches: [ main, develop ]

jobs:
  test:
    runs-on: ubuntu-latest
    
    strategy:
      matrix:
        node-version: [18.x, 20.x]
    
    steps:
    - name: Checkout code
      uses: actions/checkout@v3
    
    - name: Setup Node.js ${{ matrix.node-version }}
      uses: actions/setup-node@v3
      with:
        node-version: ${{ matrix.node-version }}
        cache: 'npm'
    
    - name: Install dependencies
      run: npm ci
    
    - name: Run tests with fixed seed (reproducibility)
      run: npm test
      env:
        # Use fixed seed for reproducible test results
        # The default seed is 42 (configured in vitest.config.js)
        # Override here if needed: VITEST_SEED: 12345
        CI: true
    
    - name: Generate coverage report
      run: npm run test:coverage
    
    - name: Upload coverage to Codecov (optional)
      uses: codecov/codecov-action@v3
      with:
        files: ./coverage/lcov.info
        flags: unittests
        name: codecov-umbrella
        fail_ci_if_error: false

  # Optional: Run tests with multiple seeds for extra confidence
  test-multiple-seeds:
    runs-on: ubuntu-latest
    
    strategy:
      matrix:
        seed: [42, 123, 456, 789, 1000]
    
    steps:
    - name: Checkout code
      uses: actions/checkout@v3
    
    - name: Setup Node.js
      uses: actions/setup-node@v3
      with:
        node-version: 20.x
        cache: 'npm'
    
    - name: Install dependencies
      run: npm ci
    
    - name: Run tests with seed ${{ matrix.seed }}
      run: npm test
      env:
        VITEST_SEED: ${{ matrix.seed }}
        CI: true
